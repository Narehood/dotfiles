# colored man pages
man() {
    env LESS_TERMCAP_mb=$'\E[01;31m' \
    LESS_TERMCAP_md=$'\E[01;38;5;74m' \
    LESS_TERMCAP_me=$'\E[0m' \
    LESS_TERMCAP_se=$'\E[0m' \
    LESS_TERMCAP_so=$'\E[01;33;03;40m' \
    LESS_TERMCAP_ue=$'\E[0m' \
    LESS_TERMCAP_us=$'\E[04;38;5;146m' \
    man "$@"
}


whatsgoingon() {
    # Use find -print0 with null-terminated strings to safely handle special characters in directory names
    while IFS= read -r -d '' dir; do
        pushd "$dir" >/dev/null || continue
        echo "$(tput bold)$(basename "$dir")$(tput sgr0)"
        if [ -z "$(git status --porcelain)" ]; then
            echo "is clean"
        else
            git status -s
        fi
        popd >/dev/null
    done < <(find . -maxdepth 1 -type d ! -name "." -print0)
}
